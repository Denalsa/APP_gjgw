/* pages/merchant/merchant.wxss */
.merchant-container {
  min-height: 100vh;
  background: #f7f7f7;
  padding-bottom: 40px;
}

.header {
  background: #d4884a;
  padding: 30px 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-title {
  font-size: 36px;
  font-weight: bold;
  color: #fff;
}

.logout-btn {
  font-size: 28px;
  color: #fff;
  padding: 8px 16px;
  border: 1px solid #fff;
  border-radius: 8px;
}

.stats-bar {
  background: #fff;
  padding: 20px 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid #eee;
}

.stats-text {
  font-size: 28px;
  color: #666;
}

.add-btn {
  background: #d4884a !important;
  color: #fff !important;
  font-size: 26px !important;
  border-radius: 8px !important;
  height: 60px !important;
  line-height: 60px !important;
  padding: 0 24px !important;
}

.dish-list {
  padding: 16px;
}

.dish-item {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.dish-img {
  width: 120px;
  height: 120px;
  border-radius: 8px;
  flex-shrink: 0;
  background: #f0f0f0;
}

.dish-info {
  flex: 1;
  margin-left: 20px;
  display: flex;
  flex-direction: column;
}

.dish-name {
  font-size: 30px;
  font-weight: bold;
  color: #333;
}

.dish-category {
  font-size: 24px;
  color: #999;
  margin-top: 6px;
}

.dish-stock {
  font-size: 24px;
  color: #666;
  margin-top: 4px;
}

.dish-actions {
  flex-shrink: 0;
  margin-left: 16px;
}

.del-btn {
  background: #e74c3c !important;
  color: #fff !important;
  font-size: 24px !important;
  border-radius: 8px !important;
  height: 56px !important;
  line-height: 56px !important;
  padding: 0 16px !important;
}

.loading-box {
  text-align: center;
  padding: 100px 0;
  font-size: 28px;
  color: #999;
}

.empty-box {
  text-align: center;
  padding: 120px 0;
}

.empty-text {
  font-size: 30px;
  color: #999;
  display: block;
  margin-bottom: 30px;
}

.empty-btn {
  background: #d4884a;
  color: #fff;
  width: 300px;
  border-radius: 12px;
  font-size: 30px;
}


.subscribe-bar {
  padding: 16px 24px;
  background: #fff;
  border-bottom: 1px solid #eee;
  text-align: center;
}
.subscribe-btn {
  background: #ffa940 !important;
  color: #fff !important;
  font-size: 26px !important;
  border-radius: 8px !important;
}
.subscribed-text {
  font-size: 26px;
  color: #52c41a;
}