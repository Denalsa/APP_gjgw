<!-- pages/merchant/merchant.wxml -->
<view class="merchant-container">
  <view class="header">
    <text class="header-title">👨‍🍳 商家管理后台</text>
    <text class="logout-btn" bindtap="logout">退出</text>
  </view>

  <view class="subscribe-bar">
    <button wx:if="{{!subscribed}}" class="subscribe-btn" bindtap="requestSubscribe">
      🔔 开启接单提醒
    </button>
    <text wx:else class="subscribed-text">✅ 接单提醒已开启</text>
  </view>

  <view class="stats-bar">
    <text class="stats-text">共 {{dishes.length}} 道菜品</text>
    <button class="add-btn" bindtap="goAddDish" size="mini">+ 新增菜品</button>
  </view>

  <view class="dish-list" wx:if="{{!loading && dishes.length > 0}}">
    <view class="dish-item" wx:for="{{dishes}}" wx:key="_id">
      <image class="dish-img" src="{{item.image}}" mode="aspectFill" />
      <view class="dish-info">
        <text class="dish-name">{{item.name}}</text>
        <text class="dish-category">{{item.category}} · ¥{{item.price}}</text>
        <text class="dish-stock">库存：{{item.stock || 0}}</text>
      </view>
      <view class="dish-actions">
        <button class="del-btn" size="mini" data-id="{{item._id}}" bindtap="deleteDish">删除</button>
      </view>
    </view>
  </view>

  <view class="loading-box" wx:if="{{loading}}"><text>加载中...</text></view>
  <view class="empty-box" wx:if="{{!loading && dishes.length === 0}}">
    <text class="empty-text">暂未添加菜品</text>
    <button class="empty-btn" bindtap="goAddDish">立即添加第一道菜</button>
  </view>
</view>