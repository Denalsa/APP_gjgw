<!-- 未提交时：确认下单界面 -->
<view wx:if="{{!orderSubmitted}}">
  <view class="cart-list">
    <view class="cart-item" wx:for="{{cart}}" wx:key="id">
    <!--   <image class="item-img" src="{{item.image}}" mode="aspectFill" binderror="onImageError" data-index="{{index}}"></image>-->
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-price">¥{{item.price}} × {{item.quantity}}</text>
      </view>
    </view>
  </view>
  
  <view class="order-note">
    <input placeholder="备注（如：少辣）" value="{{note}}" bindinput="onInputNote" />
  </view>
  
  <view class="order-total">
    <text>总价：¥{{total}}</text>
  </view>
  
  <button class="submit-btn" bindtap="submitOrder">确认并下单</button>
</view>

<!-- 提交成功后：订单快照界面 -->
<view wx:else class="order-success">
  <text class="success-title">🎉 下单成功!</text>
  <view class="order-detail">
    <text class="detail-title">订单详情：</text>
    <view class="cart-item" wx:for="{{cart}}" wx:key="id">
    <!--  <image class="item-img" src="{{item.image}}" mode="aspectFill" binderror="onImageError" data-index="{{index}}"></image>-->
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-price">¥{{item.price}} × {{item.quantity}}</text>
      </view>
    </view>
    <view class="order-note" wx:if="{{note}}">
      <text>备注：{{note}}</text>
    </view>
    <view class="order-total">
      <text>总价：¥{{total}}</text>
    </view>
    <text class="order-id" wx:if="{{orderId}}">订单编号：{{orderId}}</text>
  </view>
  <button class="back-btn" bindtap="goHome">返回首页</button>
</view>