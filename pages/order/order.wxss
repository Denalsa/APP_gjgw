.container {
  padding: 24rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.line,
.total {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

textarea {
  margin: 20rpx 0;
  width: 100%;
  height: 160rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
}
