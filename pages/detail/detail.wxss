.container {
  padding: 24rpx;
}

.banner {
  width: 100%;
  height: 360rpx;
  border-radius: 24rpx;
}

.name {
  font-size: 40rpx;
  font-weight: 700;
}

.price {
  margin-top: 8rpx;
  color: #ff7d4d;
  font-size: 34rpx;
}

.desc,
.tag {
  margin-top: 12rpx;
  color: #666;
}

.ingredients {
  margin: 20rpx 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.subtitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
