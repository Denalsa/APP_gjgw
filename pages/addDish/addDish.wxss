/* pages/addDish/addDish.wxss */
.add-dish-container {
  min-height: 100vh;
  background: #f7f7f7;
  padding-bottom: 140px;
}

.form-section {
  padding: 24px;
}

.form-item {
  background: #fff;
  border-radius: 12px;
  padding: 24px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.form-label {
  font-size: 28px;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16px;
}

.required {
  color: #e74c3c;
}

.form-input {
  width: 100%;
  height: 80px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 20px;
  font-size: 28px;
  box-sizing: border-box;
  background: #fafafa;
}

.form-textarea {
  width: 100%;
  min-height: 120px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 16px 20px;
  font-size: 28px;
  box-sizing: border-box;
  background: #fafafa;
}

.picker-view {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 20px;
  font-size: 28px;
  background: #fafafa;
  color: #333;
}

.picker-arrow {
  font-size: 36px;
  color: #999;
}

.image-upload {
  width: 200px;
  height: 200px;
  border-radius: 12px;
  overflow: hidden;
  border: 2px dashed #d0d0d0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  text-align: center;
}

.upload-icon {
  font-size: 48px;
  display: block;
}

.upload-text {
  font-size: 24px;
  color: #999;
  margin-top: 8px;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16px 24px;
  box-shadow: 0 -2px 12px rgba(0,0,0,0.06);
}

.submit-btn {
  width: 100%;
  height: 90px;
  background: #d4884a;
  color: #fff;
  font-size: 32px;
  font-weight: bold;
  border-radius: 12px;
  border: none;
  line-height: 90px;
}

.submit-btn[disabled] {
  background: #ccc;
}