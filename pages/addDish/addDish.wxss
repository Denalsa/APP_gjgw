.add-dish-container {
  min-height: 100vh;
  background: #f7f7f7;
  padding-bottom: 140px;
}

.form-section {
  padding: 24px;
}

.form-item {
  background: #fff;
  border-radius: 12px;
  padding: 24px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.form-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.required {
  color: #e74c3c;
}

.form-input, .form-textarea {
  width: 100%;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #fafafa;
  box-sizing: border-box;
}

.form-textarea {
  min-height: 120px;
}

.picker-view {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 20rpx;
  background: #fafafa;
  color: #333;
  font-size: 28rpx;
}

.picker-arrow {
  font-size: 36rpx;
  color: #999;
}

.image-upload {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #d0d0d0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.upload-placeholder {
  text-align: center;
}

.upload-icon {
  font-size: 48rpx;
  display: block;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  background: #d4884a;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
  line-height: 90rpx;
}

.submit-btn[disabled] {
  background: #ccc;
}