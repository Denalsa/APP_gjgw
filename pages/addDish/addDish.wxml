<!-- pages/addDish/addDish.wxml -->
<view class="add-dish-container">
  <view class="form-section">
    <!-- 菜品图片 -->
    <view class="form-item">
      <text class="form-label">菜品图片 <text class="required">*</text></text>
      <view class="image-upload" bindtap="chooseImage">
        <image wx:if="{{tempImage || imagePath}}" class="preview-img" src="{{tempImage || imagePath}}" mode="aspectFill" />
        <view class="upload-placeholder" wx:else>
          <text class="upload-icon">📷</text>
          <text class="upload-text">点击上传图片</text>
        </view>
      </view>
    </view>

    <!-- 菜品名称 -->
    <view class="form-item">
      <text class="form-label">菜品名称 <text class="required">*</text></text>
      <input class="form-input" placeholder="请输入菜品名称" value="{{name}}" bindinput="onInputName" />
    </view>

    <!-- 分类 -->
    <view class="form-item">
      <text class="form-label">菜品分类 <text class="required">*</text></text>
      <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker-view">
          <text>{{categories[categoryIndex]}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 价格 -->
    <view class="form-item">
      <text class="form-label">价格 (元) <text class="required">*</text></text>
      <input class="form-input" type="digit" placeholder="请输入菜品价格" value="{{price}}" bindinput="onInputPrice" />
    </view>

    <!-- 库存 -->
    <view class="form-item">
      <text class="form-label">库存数量 <text class="required">*</text></text>
      <input class="form-input" type="number" placeholder="请输入库存数量" value="{{stock}}" bindinput="onInputStock" />
    </view>

    <!-- 描述 -->
    <view class="form-item">
      <text class="form-label">菜品描述</text>
      <textarea class="form-textarea" placeholder="请输入菜品描述（选填）" value="{{description}}" bindinput="onInputDesc" maxlength="200" auto-height />
    </view>

    <!-- 原材料 -->
    <view class="form-item">
      <text class="form-label">原材料</text>
      <input class="form-input" placeholder="如：牛肉, 土豆, 胡萝卜 (逗号分隔)" value="{{ingredients}}" bindinput="onInputIngredients" />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-bar">
    <button class="submit-btn" bindtap="submitDish" loading="{{submitting}}" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '确认添加菜品'}}
    </button>
  </view>
</view>