/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #fff8f0 0%, #ffe4c4 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80px 32px 40px;
}

.login-header {
  text-align: center;
  margin-bottom: 60px;
}

.app-title {
  font-size: 48px;
  font-weight: bold;
  color: #d4884a;
  display: block;
  margin-bottom: 12px;
}

.app-subtitle {
  font-size: 28px;
  color: #8b6914;
}

.role-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.role-option {
  width: 100%;
  background: #fff;
  border-radius: 16px;
  padding: 40px 32px;
  text-align: center;
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  transition: all 0.2s;
  border: 2px solid transparent;
}

.role-option:active {
  transform: scale(0.97);
  border-color: #d4884a;
}

.role-icon {
  font-size: 64px;
  display: block;
  margin-bottom: 16px;
}

.role-name {
  font-size: 36px;
  font-weight: bold;
  color: #333;
  margin-bottom: 8px;
}

.role-desc {
  font-size: 26px;
  color: #999;
}

.customer-box {
  border-left: 8px solid #ffa940;
}

.merchant-box {
  border-left: 8px solid #d4884a;
}

.role-title {
  font-size: 32px;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30px;
}

.form-group {
  width: 100%;
  margin-bottom: 12px;
}

.password-input {
  width: 100%;
  height: 90px;
  border: 2px solid #ffcc80;
  border-radius: 12px;
  padding: 0 24px;
  font-size: 30px;
  box-sizing: border-box;
  background: #fff;
}

.error-msg {
  color: #e74c3c;
  font-size: 26px;
  margin-bottom: 16px;
  text-align: center;
}

.btn-group {
  display: flex;
  gap: 20px;
  margin-top: 20px;
}

.btn {
  flex: 1;
  height: 90px;
  line-height: 90px;
  border-radius: 12px;
  font-size: 32px;
  font-weight: bold;
  text-align: center;
  border: none;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background: #d4884a;
  color: #fff;
}